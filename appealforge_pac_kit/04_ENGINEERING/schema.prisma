generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  CLINICAL_REVIEWER
  CASE_MANAGER
  ADMISSIONS_USER
  READ_ONLY_AUDITOR
}

enum CaseStatus {
  NEW
  UPLOADING
  EXTRACTING
  NEEDS_DENIAL_REVIEW
  EVIDENCE_MAPPING
  NEEDS_EVIDENCE_REVIEW
  PACKET_DRAFTED
  PHYSICIAN_REVIEW
  APPROVED
  SENT
  WON
  LOST
  PARTIAL
  ESCALATED
  ARCHIVED
}

enum DocumentType {
  DENIAL_LETTER
  DISCHARGE_SUMMARY
  H_AND_P
  THERAPY_NOTE
  NURSING_NOTE
  WOUND_NOTE
  MEDICATION_LIST
  LAB_REPORT
  OTHER
}

enum ReviewStatus {
  AI_DRAFT
  STAFF_REVIEWED
  CLINICAL_REVIEWED
  PHYSICIAN_APPROVED
  REJECTED
}

enum AppealOutcomeType {
  WON
  LOST
  PARTIAL
  WITHDRAWN
  ESCALATED
}

model Organization {
  id          String      @id @default(cuid())
  name        String
  createdAt   DateTime    @default(now())
  facilities  Facility[]
  users       User[]
  patients    Patient[]
  cases       AuthCase[]
  auditEvents AuditEvent[]
}

model Facility {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  npi            String?
  state          String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  cases          AuthCase[]

  @@index([organizationId])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @unique
  name           String?
  role           UserRole
  mfaEnabled     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  auditEvents    AuditEvent[]

  @@index([organizationId])
}

model Patient {
  id                  String       @id @default(cuid())
  organizationId      String
  mrnHash             String?
  encryptedName       String?
  encryptedDob        String?
  encryptedMedicareId String?
  syntheticLabel      String?
  createdAt           DateTime     @default(now())
  organization        Organization @relation(fields: [organizationId], references: [id])
  cases               AuthCase[]

  @@index([organizationId])
}

model AuthCase {
  id                  String              @id @default(cuid())
  organizationId      String
  facilityId          String
  patientId           String
  serviceType         String
  planName            String
  requestType         String
  status              CaseStatus          @default(NEW)
  denialDate          DateTime?
  appealDeadlineAt    DateTime?
  expeditedCandidate  Boolean             @default(false)
  assignedOwnerId     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization        Organization        @relation(fields: [organizationId], references: [id])
  facility            Facility            @relation(fields: [facilityId], references: [id])
  patient             Patient             @relation(fields: [patientId], references: [id])
  documents           Document[]
  denialFindings      DenialFinding[]
  criteria            Criterion[]
  evidenceItems       EvidenceItem[]
  evidenceGaps        EvidenceGap[]
  packetVersions      PacketVersion[]
  communicationLogs   CommunicationLog[]
  appealOutcomes      AppealOutcome[]

  @@index([organizationId])
  @@index([facilityId])
  @@index([patientId])
  @@index([status])
  @@index([appealDeadlineAt])
}

model Document {
  id              String          @id @default(cuid())
  caseId          String
  docType         DocumentType    @default(OTHER)
  filename        String
  storageKey      String
  sha256          String
  pageCount       Int?
  extractionState String          @default("pending")
  uploadedBy      String?
  createdAt       DateTime        @default(now())

  case            AuthCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  pages           ExtractedPage[]
  evidenceItems   EvidenceItem[]

  @@index([caseId])
  @@index([docType])
}

model ExtractedPage {
  id                   String   @id @default(cuid())
  documentId           String
  pageNumber           Int
  text                 String
  extractionConfidence Float?
  createdAt            DateTime @default(now())

  document             Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([documentId])
}

model DenialFinding {
  id                    String   @id @default(cuid())
  caseId                String
  denialReason          String
  payerRationale        String?
  appealInstructions    String?
  parsedJson            Json
  reviewerConfirmed     Boolean  @default(false)
  sourceCitationJson    Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  case                  AuthCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Criterion {
  id                    String         @id @default(cuid())
  caseId                String
  label                 String
  description           String
  sourceType            String
  sourceReference       String?
  requiredEvidenceJson  Json
  priority              String         @default("medium")
  createdAt             DateTime       @default(now())

  case                  AuthCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  evidenceItems         EvidenceItem[]
  evidenceGaps          EvidenceGap[]

  @@index([caseId])
}

model EvidenceItem {
  id                 String       @id @default(cuid())
  caseId             String
  criterionId        String
  documentId         String
  pageNumber         Int
  quote              String
  normalizedSummary  String
  confidence         Float
  reviewerStatus     ReviewStatus @default(AI_DRAFT)
  reviewerNote       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  case               AuthCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  criterion          Criterion    @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  document           Document     @relation(fields: [documentId], references: [id])

  @@index([caseId])
  @@index([criterionId])
  @@index([documentId])
  @@index([reviewerStatus])
}

model EvidenceGap {
  id              String     @id @default(cuid())
  caseId          String
  criterionId     String
  gapText         String
  whyNeeded       String?
  suggestedOwner  String?
  priority        String     @default("medium")
  resolvedAt      DateTime?
  createdAt       DateTime   @default(now())

  case            AuthCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  criterion       Criterion  @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([criterionId])
}

model PacketVersion {
  id              String       @id @default(cuid())
  caseId          String
  versionNumber   Int
  status          ReviewStatus @default(AI_DRAFT)
  packetMarkdown  String
  pdfStorageKey   String?
  generatedBy     String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime     @default(now())

  case            AuthCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, versionNumber])
  @@index([caseId])
}

model CommunicationLog {
  id                  String    @id @default(cuid())
  caseId              String
  channel             String
  destination         String?
  sentAt              DateTime?
  confirmationNumber  String?
  notes               String?
  createdAt           DateTime  @default(now())

  case                AuthCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model AppealOutcome {
  id                  String            @id @default(cuid())
  caseId              String
  outcome             AppealOutcomeType
  decisionDate        DateTime?
  approvedDays        Int?
  denialUpheldReason  String?
  notes               String?
  createdAt           DateTime          @default(now())

  case                AuthCase          @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model AuditEvent {
  id              String       @id @default(cuid())
  organizationId  String
  userId          String?
  action          String
  subjectType     String
  subjectId       String
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime     @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([subjectType, subjectId])
  @@index([createdAt])
}
